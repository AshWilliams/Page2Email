{
  "manifest_version": 3,
  "name": "Page2Email",
  "version": "1.0.0",
  "description": "Capture the current page as a screenshot or PDF and email it instantly.",
  "permissions": ["activeTab", "tabs", "scripting", "downloads", "storage", "identity", "identity.email"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Page2Email – Capture & Email this page",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/html2pdf.bundle.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
